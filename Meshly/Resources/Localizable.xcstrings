    "onboarding.page1.subtitle" : {
      "comment" : "Используйте LiDAR датчик для создания точных 3D-моделей объектов вокруг вас",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use the LiDAR sensor to create accurate 3D models of objects around you."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте LiDAR датчик для создания точных 3D-моделей объектов вокруг вас"
          }
        }
      }
    },
    "onboarding.page1.title" : {
      "comment" : "Сканируйте мир в 3D",
